{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/agents",
      "regex": "^/agents(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/agents(?:/)?$"
    },
    {
      "page": "/aria",
      "regex": "^/aria(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/aria(?:/)?$"
    },
    {
      "page": "/chat",
      "regex": "^/chat(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/chat(?:/)?$"
    },
    {
      "page": "/code",
      "regex": "^/code(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/code(?:/)?$"
    },
    {
      "page": "/comms",
      "regex": "^/comms(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/comms(?:/)?$"
    },
    {
      "page": "/content",
      "regex": "^/content(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/content(?:/)?$"
    },
    {
      "page": "/finances/accounting",
      "regex": "^/finances/accounting(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/finances/accounting(?:/)?$"
    },
    {
      "page": "/finances/revenue",
      "regex": "^/finances/revenue(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/finances/revenue(?:/)?$"
    },
    {
      "page": "/knowledge",
      "regex": "^/knowledge(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/knowledge(?:/)?$"
    },
    {
      "page": "/ops",
      "regex": "^/ops(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/ops(?:/)?$"
    },
    {
      "page": "/schedule",
      "regex": "^/schedule(?:/)?$",
